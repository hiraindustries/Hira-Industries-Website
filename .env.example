# Supabase public browser/server read configuration.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Backward-compatible alias used by some Supabase projects.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase service role key. Never prefix this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Approved admin email list. The application still enforces its internal allowlist.
ADMIN_EMAILS=hiraindustrieskhurja@gmail.com

# Server-only CRM feature flag. Keep false until the CRM migration is applied and tested.
CRM_ENABLED=false

# Server-only Website CMS feature flag. Keep false until CMS workflows are tested.
CMS_ENABLED=false

# Optional Google Analytics measurement ID.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional contact enquiry email notifications.
RESEND_API_KEY=
CONTACT_NOTIFICATION_TO=hiraindustrieskhurja@gmail.com
CONTACT_NOTIFICATION_FROM="Hira Industries Website <onboarding@resend.dev>"

# Optional search-engine verification meta tags.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Optional IndexNow key. Configure the same value in Bing Webmaster Tools.
INDEXNOW_KEY=
